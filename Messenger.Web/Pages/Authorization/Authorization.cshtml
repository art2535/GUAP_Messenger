@page
@model Messenger.Web.Pages.Authorization.AuthorizationModel
@{
    ViewData["Title"] = "Вход в систему";
    Layout = "_Layout";
}

<script src="https://cdn.tailwindcss.com"></script>
<script src="https://unpkg.com/feather-icons"></script>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
<partial name="_LayoutPWA"/>

<style>
    html, body {
        height: 100%;
        margin: 0;
        font-family: 'Roboto', sans-serif;
        background-color: #f8fafc;
        overflow: hidden;
    }

    .guap-gradient {
        background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
    }

    .auth-wrapper {
        position: absolute;
        top: 170px;
        left: 0;
        width: 100%;
        height: calc(100vh - 160px);
        display: flex;
        justify-content: center;
        align-items: start;
    }

    .auth-card {
        width: 100%;
        max-width: 380px;
        background-color: white;
        border-radius: 1rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        padding: 2.5rem 1.75rem;
    }

    .big-button {
        transition: all 0.2s ease;
    }

        .big-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.4);
        }
</style>

<div class="auth-wrapper">
    <div class="auth-card space-y-8 text-center">
        <div>
            <div class="w-24 h-24 rounded-full overflow-hidden mx-auto mb-5 border-4 border-blue-100">
                <img src="~/images/logo.png" alt="GUAP Messenger Logo" class="w-full h-full object-cover">
            </div>
            <h1 class="text-3xl font-bold text-gray-800 mb-2">GUAP Messenger</h1>
            <p class="text-gray-600 text-lg">Войдите через систему ЕТА ГУАП</p>
        </div>

        <div class="pt-4">
            <a href="/Authorization/Authorization?handler=EtaLogin"
               class="big-button w-full flex justify-center items-center py-3 px-5 border border-transparent rounded-xl shadow-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 font-medium text-base transition-all">
                <i data-feather="log-in" class="w-5 h-5 mr-3"></i>
                Войти через ЕТА ГУАП
            </a>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        feather.replace();

        const errors = [];
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <text>errors.push(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ErrorMessage)));</text>
        }
        @foreach (var key in ViewData.ModelState.Keys)
        {
            var state = ViewData.ModelState[key];
            foreach (var error in state.Errors)
            {
                <text>errors.push(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(error.ErrorMessage)));</text>
            }
        }
        if (errors.length > 0) {
            alert(errors.join("\n"));
        }
    });
</script>