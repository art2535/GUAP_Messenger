@page "{chatId?}"
@model Messenger.Web.Pages.Account.ChatsModel
@{
    ViewData["Title"] = "Чаты";
    Layout = null;

    var tokenSaved = ViewData["TokenSaved"] as bool? ?? false;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <meta id="access-token-meta" content="@HttpContext.Session.GetString("ACCESS_TOKEN")" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/feather-icons"></script>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <partial name="_LayoutPWA"/>
    <link rel="stylesheet" href="~/css/account/chats.css" />
</head>
<body class="h-screen">
    <div class="flex h-full">
        <div class="w-80 bg-white border-r border-gray-200 flex flex-col">
            <div class="p-4 border-b border-gray-200 flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="guap-gradient text-white w-10 h-10 rounded-full flex items-center justify-center">
                        <i data-feather="message-square" class="w-5 h-5"></i>
                    </div>
                    <h1 class="font-bold text-lg">GUAP Messenger</h1>
                </div>
                <a asp-page="/Account/Settings" class="text-gray-500 hover:text-gray-700"><i data-feather="settings" class="w-5 h-5"></i></a>
            </div>

            <div class="p-3 border-b border-gray-200 space-y-2">
                <div class="relative">
                    <input type="text" id="chat-search" placeholder="Поиск по чатам"
                           class="w-full pl-10 pr-10 py-2 bg-gray-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition">
                    <i data-feather="search" class="absolute left-3 top-2.5 text-gray-400 w-5 h-5"></i>
                    <button id="clear-search" class="absolute right-3 top-2.5 text-gray-400 hover:text-gray-600 hidden">
                        <i data-feather="x" class="w-5 h-5"></i>
                    </button>
                </div>
                <button id="create-chat-btn" class="w-full guap-gradient text-white py-2 px-4 rounded-lg hover:opacity-90 transition flex items-center justify-center">
                    <i data-feather="plus" class="w-4 h-4 mr-2"></i> Создать чат
                </button>
            </div>

            <div class="flex-1 overflow-y-auto relative" id="chats-list">
                <div id="chats-status-container" class="flex flex-col items-center justify-center">
                    <div id="chats-loading" class="text-gray-500 p-4">Загрузка чатов...</div>

                    <div id="empty-state" class="hidden flex-col items-center justify-center p-8 text-center text-gray-500">
                        <div class="bg-gray-100 p-4 rounded-full mb-4">
                            <i data-feather="message-square" class="w-8 h-8"></i>
                        </div>
                        <p class="text-lg font-medium">Чатов нет</p>
                        <p class="text-sm">Начните общение прямо сейчас</p>
                    </div>
                </div>

                <div id="chats-container"></div>
            </div>

            <div class="p-4 border-t border-gray-200">
                <div class="flex items-center space-x-3">
                    <div class="relative w-10 h-10">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <img id="current-user-avatar"
                                 src="@Model.AvatarUrl?t=@DateTime.Now.Ticks"
                                 alt="Аватар"
                                 class="w-10 h-10 rounded-full object-cover shadow-md">
                        }
                        else
                        {
                            <div id="current-user-avatar-placeholder"
                                 class="guap-gradient w-10 h-10 rounded-full flex items-center justify-center shadow-md">
                                <i data-feather="user" class="w-5 h-5 text-white"></i>
                            </div>
                        }
                    </div>
                    <div>
                        <p class="font-medium">@Model.UserName</p>
                        <p class="text-xs text-gray-500">@Model.UserRole</p>
                    </div>
                    <div id="connection-status" class="relative ml-auto group">
                        <div id="status-dot" class="w-3 h-3 bg-gray-400 rounded-full"></div>
                        <div id="status-tooltip" class="absolute bottom-full right-0 mb-2 px-2 py-1 text-xs text-white bg-gray-800 rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition">
                            Подключение...
                        </div>
                    </div>
                    <form asp-page="/Authorization/Logout" method="post" class="ml-2">
                        <button type="submit" class="text-gray-500 hover:text-red-600"><i data-feather="log-out" class="w-5 h-5"></i></button>
                    </form>
                </div>
            </div>
        </div>

        <div class="flex-1 flex flex-col" id="right-panel">
            <div id="chat-header"
                 class="hidden p-4 border-b border-gray-200 bg-white flex items-center justify-between cursor-pointer hover:bg-gray-50 transition">

                <div onclick="openChatInfo()" class="flex items-center space-x-3 flex-1 min-w-0 cursor-pointer">
                    <div class="relative">
                        <img id="chat-info-avatar"
                             src="https://novgorodskij-r49.gosweb.gosuslugi.ru/netcat_files/9/260/user_test.png"
                             class="w-11 h-11 rounded-full object-cover ring-2 ring-white shadow">
                        <span id="chat-online-indicator"
                              class="absolute bottom-0 right-0 w-3.5 h-3.5 bg-green-500 rounded-full border-2 border-white hidden"></span>
                    </div>
                    <div class="min-w-0">
                        <h2 id="chat-title" class="font-semibold text-lg truncate">Чат</h2>
                        <div id="chat-status-area" class="text-sm text-gray-500 truncate flex items-center gap-2">
                            <span id="chat-subtitle"></span>

                            <div id="typing-indicator" class="typing-indicator hidden items-center gap-1">
                                <span id="typing-name" class="font-medium text-blue-600"></span>
                                <span class="typing-dots text-blue-600">печатает</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex items-center gap-2">
                    <button id="search-toggle-btn"
                            onclick="toggleMessageSearch()"
                            class="w-9 h-9 flex items-center justify-center text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-full transition">
                        <i data-feather="search" class="w-5 h-5"></i>
                    </button>

                    <div id="message-search-bar" class="hidden items-center bg-gray-100 rounded-3xl px-4 py-1.5 w-80 transition-all">
                        <i data-feather="search" class="w-4 h-4 text-gray-400 mr-2"></i>
                        <input type="text"
                               id="message-search-input"
                               class="flex-1 bg-transparent outline-none text-sm placeholder-gray-400"
                               placeholder="Поиск по сообщениям"
                               onkeypress="if(event.key === 'Enter') performMessageSearch()">

                        <button onclick="clearMessageSearch(true)"
                                class="ml-2 text-gray-400 hover:text-gray-600 text-xl leading-none">
                            ✕
                        </button>
                    </div>

                    <button class="w-9 h-9 flex items-center justify-center text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-full transition">
                        <i data-feather="phone" class="w-5 h-5"></i>
                    </button>
                    <button onclick="openChatInfo()"
                            class="w-9 h-9 flex items-center justify-center text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-full transition">
                        <i data-feather="more-vertical" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>

            <div id="messages-container"
                 class="hidden flex-1 p-4 overflow-y-auto bg-gray-50">
            </div>

            <div id="search-navigation" class="hidden fixed right-6 bottom-32 z-50 flex flex-col items-end gap-2 pointer-events-auto">
                <div id="search-counter"
                     class="hidden bg-white/95 backdrop-blur-md shadow-md border border-gray-200 text-xs font-medium text-gray-600 px-3.5 py-1.5 rounded-2xl mb-1">
                    <span id="current-count">1</span> из <span id="total-count">5</span>
                </div>

                <button onclick="navigateSearch(-1)"
                        class="w-11 h-11 bg-white/95 backdrop-blur-md shadow-xl hover:shadow-2xl border border-gray-200 rounded-2xl flex items-center justify-center text-gray-700 hover:text-blue-600 transition-all active:scale-95">
                    <i data-feather="chevron-up" class="w-6 h-6"></i>
                </button>

                <button onclick="navigateSearch(1)"
                        class="w-11 h-11 bg-white/95 backdrop-blur-md shadow-xl hover:shadow-2xl border border-gray-200 rounded-2xl flex items-center justify-center text-gray-700 hover:text-blue-600 transition-all active:scale-95">
                    <i data-feather="chevron-down" class="w-6 h-6"></i>
                </button>
            </div>

            <div id="chat-input-area" class="hidden p-3 border-t border-gray-200 bg-white">
                <div id="blocked-notice" class="hidden flex items-center justify-center p-3 bg-gray-100 text-gray-500 rounded-lg text-sm font-medium italic">
                    <i data-feather="slash" class="w-4 h-4 mr-2"></i>
                    <span id="blocked-notice-text">Отправка сообщений ограничена</span>
                </div>

                <div id="input-section-container">
                    <div id="blocked-ui" class="hidden p-4 bg-gray-50 text-center text-red-500 font-medium italic">
                        Чат заблокирован
                    </div>

                    <div id="normal-input-ui">
                        <div class="flex items-center space-x-2">
                            <label for="file-input" class="cursor-pointer text-gray-500 hover:text-gray-700">
                                <i data-feather="paperclip" class="w-5 h-5"></i>
                            </label>
                            <input id="file-input" type="file" class="hidden" multiple>
                            <input id="message-input"
                                   type="text"
                                   placeholder="Напишите сообщение..."
                                   class="flex-1 px-4 py-2 bg-gray-100 rounded-full focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white">
                            <button id="send-button" class="text-gray-500 hover:text-gray-700">
                                <i data-feather="send" class="w-5 h-5"></i>
                            </button>
                        </div>
                        <div id="attached-files" class="mt-2 flex flex-wrap gap-2"></div>
                    </div>
                </div>
            </div>

            <div id="empty-right-panel"
                 class="flex-1 flex flex-col items-center justify-center bg-gray-50 text-gray-400">
                <div class="w-20 h-20 bg-white rounded-3xl shadow-sm flex items-center justify-center mb-6">
                    <i data-feather="message-square" class="w-10 h-10"></i>
                </div>
                <p class="text-xl font-medium text-gray-600 mb-1">GUAP Messenger</p>
                <p class="text-sm text-center max-w-[240px]">
                    Выберите чат из списка слева,<br>чтобы начать общение
                </p>
            </div>
        </div>
    </div>

    <div id="lightbox" class="lightbox" onclick="this.classList.remove('show'); lightboxImg.src=''">
        <img id="lightbox-img" src="" alt="">
    </div>

    <div id="create-chat-modal" class="modal">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-8 relative">
            <div class="flex items-center justify-between mb-8">
                <h3 class="text-2xl font-bold text-gray-900">Новый чат</h3>
                <button id="close-modal" class="text-gray-400 hover:text-gray-600 transition"><i data-feather="x" class="w-7 h-7"></i></button>
            </div>
            <div class="grid grid-cols-2 gap-4 mb-8">
                <label class="relative cursor-pointer">
                    <input type="radio" name="chat-type" value="private" checked class="sr-only peer">
                    <div class="bg-gray-50 peer-checked:bg-blue-50 peer-checked:border-blue-500 border-2 border-gray-200 rounded-xl p-5 text-center transition-all hover:bg-gray-100">
                        <i data-feather="user" class="w-10 h-10 mx-auto mb-3 text-gray-600 peer-checked:text-blue-600"></i>
                        <span class="block text-sm font-medium text-gray-700">Приватный</span>
                    </div>
                </label>
                <label class="relative cursor-pointer">
                    <input type="radio" name="chat-type" value="group" class="sr-only peer">
                    <div class="bg-gray-50 peer-checked:bg-blue-50 peer-checked:border-blue-500 border-2 border-gray-200 rounded-xl p-5 text-center transition-all hover:bg-gray-100">
                        <i data-feather="users" class="w-10 h-10 mx-auto mb-3 text-gray-600 peer-checked:text-blue-600"></i>
                        <span class="block text-sm font-medium text-gray-700">Групповой</span>
                    </div>
                </label>
            </div>
            <div id="group-name-container" class="mb-6 hidden">
                <label class="block text-sm font-medium text-gray-700 mb-2">Название группы</label>
                <input type="text" id="chat-name" placeholder="Например: Друзья ГУАПа" class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-2">Добавить участников</label>
                <div class="relative">
                    <input type="text" id="user-search" placeholder="Поиск по имени..." autocomplete="off" class="w-full px-4 py-3 pl-11 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <i data-feather="search" class="absolute left-4 top-3.5 w-5 h-5 text-gray-400"></i>
                </div>
                <div id="user-search-results"></div>
            </div>
            <div id="selected-users" class="flex flex-wrap gap-2 mb-6"></div>
            <div class="flex justify-end gap-3">
                <button id="cancel-create" class="px-6 py-3 text-gray-600 hover:text-gray-800 font-medium transition">Отмена</button>
                <button id="confirm-create" class="px-8 py-3 bg-blue-600 text-white rounded-xl hover:bg-blue-700 font-medium shadow-lg transition transform hover:scale-105">Создать</button>
            </div>
        </div>
    </div>

    <div id="chat-info-modal" class="modal">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg p-8 max-h-screen overflow-y-auto">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-2xl font-bold">Информация о чате</h3>
                <button onclick="document.getElementById('chat-info-modal').classList.remove('show')" class="text-gray-400 hover:text-gray-600">
                    <i data-feather="x" class="w-7 h-7"></i>
                </button>
            </div>

            <div class="flex flex-col items-center mb-8">
                <img id="modal-chat-avatar" src="https://novgorodskij-r49.gosweb.gosuslugi.ru/netcat_files/9/260/user_test.png" class="w-24 h-24 rounded-full object-cover mb-4">
                <input type="text" id="modal-chat-name" class="text-2xl font-bold text-center bg-transparent border-b-2 border-transparent focus:border-blue-500 outline-none w-full" placeholder="Название чата">
                <p id="modal-chat-type" class="text-sm text-gray-500 mt-2"></p>
            </div>

            <div class="mb-6">
                <div class="flex items-center justify-between mb-3">
                    <h4 class="font-semibold">Участники <span id="participants-count" class="text-gray-500"></span></h4>
                    <button id="add-participant-btn" class="text-blue-600 text-sm font-medium hover:underline">+ Добавить</button>
                </div>
                <div id="participants-list" class="space-y-2"></div>
            </div>

            <div class="mt-8 pt-6 border-t border-gray-200">
                <button id="delete-chat-btn" class="w-full px-6 py-3 bg-red-600 hover:bg-red-700 text-white rounded-xl font-medium transition transform hover:scale-105">
                    Удалить чат
                </button>
            </div>
            <div class="flex justify-end gap-3 mt-8">
                <button onclick="document.getElementById('chat-info-modal').classList.remove('show')" class="px-6 py-3 text-gray-600 font-medium">Отмена</button>
                <button id="save-chat-info" class="px-8 py-3 bg-blue-600 text-white rounded-xl font-medium opacity-0 pointer-events-none transition">Сохранить изменения</button>
            </div>
        </div>
    </div>

    <script src="~/app.js"></script>
    <script src="~/js/account/chats/init-token.js"></script>
    <script src="~/js/account/chats/config.js"></script>
    <script src="~/js/account/chats/globals.js"></script>
    <script src="~/js/account/chats/fetch.js"></script>
    <script src="~/js/account/chats/utils.js"></script>
    <script src="~/js/account/chats/blocked.js"></script>
    <script src="~/js/account/chats/chat-ui.js"></script>
    <script src="~/js/account/chats/messages.js"></script>
    <script src="~/js/account/chats/search.js"></script>
    <script src="~/js/account/chats/signalr.js"></script>
    <script src="~/js/account/chats/modals.js"></script>
    <script src="~/js/account/chats/main.js"></script>
</body>
</html>